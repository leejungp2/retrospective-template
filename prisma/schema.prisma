generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  retrospectives Retrospective[]
  actionItems    ActionItem[]
  tags           Tag[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Template Models ───

model Template {
  id               String   @id @default(cuid())
  key              String   @unique
  name             String
  description      String
  supportedPeriods String[] // ["daily", "weekly", "yearly"]
  createdAt        DateTime @default(now())

  sections       TemplateSection[]
  retrospectives Retrospective[]

  @@map("templates")
}

model TemplateSection {
  id         String @id @default(cuid())
  templateId String
  key        String
  title      String
  prompt     String
  blockType  String @default("text") // text, list, etc.
  order      Int

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, key])
  @@map("template_sections")
}

// ─── Retrospective Models ───

enum PeriodType {
  daily
  weekly
  yearly
}

enum InputMode {
  wizard
  coach
}

enum RetroStatus {
  draft
  completed
}

model Retrospective {
  id         String      @id @default(cuid())
  userId     String
  templateId String
  periodType PeriodType
  inputMode  InputMode   @default(wizard)
  status     RetroStatus @default(draft)
  dateStart  DateTime
  dateEnd    DateTime
  context    String?     @db.Text
  summary    String?     @db.Text
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template    Template          @relation(fields: [templateId], references: [id])
  blocks      Block[]
  actionItems ActionItem[]
  tags        RetrospectiveTag[]
  shareLinks  ShareLink[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("retrospectives")
}

model Block {
  id              String @id @default(cuid())
  retrospectiveId String
  sectionKey      String
  type            String @default("text")
  contentJson     Json
  order           Int

  retrospective Retrospective @relation(fields: [retrospectiveId], references: [id], onDelete: Cascade)

  @@index([retrospectiveId, sectionKey])
  @@map("blocks")
}

// ─── Tag Models ───

model Tag {
  id     String @id @default(cuid())
  name   String
  userId String

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  retrospectives RetrospectiveTag[]

  @@unique([name, userId])
  @@map("tags")
}

model RetrospectiveTag {
  retrospectiveId String
  tagId           String

  retrospective Retrospective @relation(fields: [retrospectiveId], references: [id], onDelete: Cascade)
  tag           Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([retrospectiveId, tagId])
  @@map("retrospective_tags")
}

// ─── Action Item Models ───

enum ActionFrequency {
  once
  daily
  weekly
}

enum ActionStatus {
  pending
  in_progress
  completed
  skipped
}

model ActionItem {
  id              String          @id @default(cuid())
  retrospectiveId String
  userId          String
  title           String
  dueDate         DateTime?
  frequency       ActionFrequency @default(once)
  status          ActionStatus    @default(pending)
  successCriteria String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  retrospective Retrospective   @relation(fields: [retrospectiveId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs          ActionItemLog[]

  @@index([userId, status])
  @@map("action_items")
}

model ActionItemLog {
  id           String       @id @default(cuid())
  actionItemId String
  status       ActionStatus
  note         String?
  loggedAt     DateTime     @default(now())

  actionItem ActionItem @relation(fields: [actionItemId], references: [id], onDelete: Cascade)

  @@map("action_item_logs")
}

// ─── Share Models ───

enum ShareScope {
  full
  summary
  actions
}

enum SharePermission {
  view
}

model ShareLink {
  id              String          @id @default(cuid())
  retrospectiveId String
  token           String          @unique @default(cuid())
  scope           ShareScope      @default(full)
  permission      SharePermission @default(view)
  expiresAt       DateTime?
  createdAt       DateTime        @default(now())

  retrospective Retrospective @relation(fields: [retrospectiveId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("share_links")
}
